{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "enabledManagers": [
    "docker-compose",
    "helm-values",
    "helmfile",
    "kustomize",
    "kubernetes",
    "regex",
    "custom.regex"
  ],
  "schedule": ["before 8am"],
  "timezone": "Europe/Berlin",
  "commitMessageAction": "update",
  "packageRules": [
    {
      "description": "Do not let kubernetes manager rewrite internal registry images to docker.io",
      "matchManagers": ["kubernetes"],
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/^docker\\.wevelsiep\\.com\\//"],
      "enabled": false
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "matchDatasources": ["docker"],
      "allowedVersions": "/^v?[0-9]+(\\.[0-9]+){0,2}$/"
    },
    {
      "matchDatasources": ["custom.k3s"],
      "automerge": false
    }
  ],
  "kubernetes": {
    "managerFilePatterns": ["/\\.ya?ml$/"]
  },
  "regexManagers": [
    {
      "description": "Update docker.wevelsiep.com images using docker.io tags, but keep docker.wevelsiep.com in YAML",
      "fileMatch": ["\\.ya?ml$"],
      "matchStrings": [
        "image:\\s*docker\\.wevelsiep\\.com\\/(?<depName>[^\\s:\"']+):(?<currentValue>[^\\s\"']+)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker",
      "depNameTemplate": "{{depName}}",
      "autoReplaceStringTemplate": "image: docker.wevelsiep.com/{{depName}}:{{newValue}}"
    }
  ],
  "customDatasources": {
    "k3s": {
      "defaultRegistryUrlTemplate": "https://update.k3s.io/v1-release/channels",
      "transformTemplates": [
        "{\"releases\":[{\"version\": $$.(data[id = 'stable'].latest),\"sourceUrl\":\"https://github.com/k3s-io/k3s\",\"changelogUrl\":$join([\"https://github.com/k3s-io/k3s/releases/tag/\",data[id = 'stable'].latest])}],\"sourceUrl\": \"https://github.com/k3s-io/k3s\",\"homepage\": \"https://k3s.io/\"}"
      ]
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/infrastructure/system-upgrade/plans/.+\\.ya?ml$/"],
      "matchStrings": ["version: (?<currentValue>v[\\d]+\\.[\\d]+\\.[\\d]+\\+k3s\\d+)"],
      "depNameTemplate": "k3s",
      "versioningTemplate": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(?<compatibility>\\+k3s)(?<build>\\d+)$",
      "datasourceTemplate": "custom.k3s"
    }
  ]
}