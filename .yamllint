extends: default

rules:
  line-length:
    max: 200
    allow-non-breakable-inline-mappings: true
  indentation:
    spaces: 2
    indent-sequences: consistent
  document-start: disable
  comments:
    min-spaces-from-content: 1

ignore: |
  .github/*
  .gitignore
  .yamllint
  README.md
  LICENSE
  cluster/flux-system/**
